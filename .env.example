# Copy this file to .env for local development.
# On Render, set these under your Web Service's "Environment" tab instead —
# do not upload a real .env file to your repo.

# Get this from https://resend.com after creating a free account
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Must be an address on a domain you've verified in Resend,
