# Copy this file to .env for local development.
# On Render, set these under your Web Service's "Environment" tab instead —
# do not upload a real .env file to your repo.

# Get this from Brevo dashboard > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxx

# Must be a verified sender in your Brevo account
SENDER_EMAIL=you@example.com
SENDER_NAME=Adriano Law Office

# Where inquiry notifications should be sent — his real inbox
TO_EMAIL=ernestoadrianoiii@example.com
